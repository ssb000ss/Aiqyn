# ─────────────────────────────────────────────────────────────
# Aiqyn — example env file. Copy to `.env` and edit as needed.
#   cp .env.example .env
# All vars have sensible defaults — only override what you need.
# ─────────────────────────────────────────────────────────────

# ── Ollama (LLM backend) ─────────────────────────────────────
# Primary model for F-01 (perplexity) and F-14 (token rank).
AIQYN_OLLAMA_BASE_URL=http://localhost:11434
AIQYN_OLLAMA_MODEL=qwen3:8b

# Secondary model for F-16 Binoculars dual-model ratio.
# Set to empty string to disable.
AIQYN_OLLAMA_SECONDARY_MODEL=qwen3:1.7b

# Embedding model for F-12 coherence via cosine similarity.
# Without this, F-12 falls back to spaCy lemmas or surface tokens.
AIQYN_OLLAMA_EMBED_MODEL=nomic-embed-text

# ── llama-cpp fallback (when Ollama is unavailable) ──────────
# Path to a local GGUF model. Leave empty to auto-discover in
# ./models/ or ~/.local/share/aiqyn/models/.
# AIQYN_MODEL_PATH=
# AIQYN_GPU_LAYERS=0       # 0 = CPU-only; 32+ for full GPU offload

# ── Scoring behaviour ────────────────────────────────────────
# "general" — blogs, social media. "formal" — official documents (default).
AIQYN_TEXT_DOMAIN=formal

# Verdict thresholds.
# AIQYN_THRESHOLD_HUMAN=0.35
# AIQYN_THRESHOLD_AI=0.65

# Platt calibration file. "" = auto-load data/calibration.json if it
# exists. "disabled" = skip even if the file is present.
# AIQYN_CALIBRATION_PATH=

# Blend mean segment score into overall (0.0 = off, 1.0 = full).
# AIQYN_SEGMENT_WEIGHT=0.0

# How many evidence items to include in the result.
# AIQYN_EVIDENCE_TOP_N=5

# ── App ──────────────────────────────────────────────────────
# AIQYN_LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
# AIQYN_THEME=dark
